{
  "expo": {
    "name": "Chuka University App",
    "slug": "chuka-university-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chukaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f2f15",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.chukauniversityapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f4f7f5",
          "dark": {
            "backgroundColor": "#0f2f15"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://chuka-backend.onrender.com/api",
      "supabaseUrl": "https://xgbnbaiucjxsxkwbmoih.supabase.co",
      "supabaseAnonKey": "sb_publishable_YgBoefQwI7e4s5bMGTbIwg_mWeu50R7"
    }
  }
}
