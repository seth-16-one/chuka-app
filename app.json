{
  "expo": {
    "name": "Chuka University App",
    "slug": "chuka-university-app",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chukaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.chukauniversityapp",
      "ndkVersion": "25.2.9519653",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0f2f15",
        "foregroundImage": "./assets/images/adaptive-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Chuka University App to access your location for attendance, campus services, and nearby features."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f4f7f5",
          "dark": {
            "backgroundColor": "#0f2f15"
          }
        }
      ],
      "expo-video",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bc450564-74ed-4424-9b98-c56aeaf8f1c7",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "apiBaseUrl": "https://chuka-backend.sethtech.deno.net/api",
      "supabaseUrl": "https://mftyhqblkuniccesnurw.supabase.co",
      "supabaseAnonKey": "sb_publishable_YEyYzaS6Xbhe-Kjf6om_3w_a92crokS",
      "router": {},
      "eas": {
        "projectId": "bc450564-74ed-4424-9b98-c56aeaf8f1c7"
      }
    }
  }
}
